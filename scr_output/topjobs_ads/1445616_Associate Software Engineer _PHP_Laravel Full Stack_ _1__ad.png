                                        <input name="chkGovt" type="checkbox" id="chkGovt" onClick=" clearBox(this); document.frmQuickVacancySearch.submit();" value="Y" disabled="disabled" hidden><input type="text" size="10" id="darkRedBG" style="border: 0" disabled="disabled">
                                        <input name="chkNGO" type="checkbox" id="chkNGO" onClick="clearBox(this); document.frmQuickVacancySearch.submit();" value="Y" disabled="disabled" hidden><input type="text" size="3" id="darkRedBG" style="border: 0" disabled="disabled">
                                        <input name="chkParttime" type="checkbox" id="chkParttime" onClick="clearBox(this); document.frmQuickVacancySearch.submit();" value="Y" disabled="disabled" hidden><input type="text" size="9" id="darkRedBG" style="border: 0" disabled="disabled">
