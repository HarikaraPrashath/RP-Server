                                    <!--cc3203-->
                                <div class="search-bar">
                                    
                                    <input name="txtKeyWord" type="text" class="text-box" id="txtKeyWord" onClick="clearBox(this)" placeholder="Search by keywords" size="25"  maxlength="40" />   <!-- CC 3376 -->
                                    <input name="txtJSCode" type="text" class="text-box" id="txtJSCode" onclick="clearBox(this)" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');" placeholder="Search by Job Ref Number" size="25" maxlength="10"/>
                                    <input name="btnSearch" type="submit" class="btn" id="btnSearch" value="Search" disabled="disabled">
                                    <input name="hdnCurrentPage" id="hdnCurrentPage" type="hidden" value='1'>
                                    <input name="blockSize" id="blockSize" type="hidden" value='18'>
                                    <input name="CallerPage" id="CallerPage" type="hidden" value='index.jsp'>
                                    <span class="formText"></span><a href="javascript:searchtips()" title="Tips on how best to search for jobs"><i class="fa fa-info-circle" aria-hidden="true"></i></a><span class="formText"></span>
                                    <script type="text/javascript">
                                        $(document).ready(function() {
                                            $('#btnSearch').prop('disabled', true);
                                            
                                            $('#txtKeyWord, #txtJSCode').on('input', function() {
                                                  var val = $('#txtKeyWord, #txtJSCode').filter(function() {
                                                        return this.value.trim().length !== 0;
                                                }).length === 0;
                                                
                                                $('#btnSearch').prop('disabled', val);
                                            });
                                        });
                                    </script>
                                </div>
