<script>
var currentState = false;
/**
 * setSize - if the window size above 992px side menu bar will apear and also side menu bar goes in between vacancy list and 
 category panel, the screen size is below 992px
 */
function setSize() {
  var state = $(window).width() < 992;
  if (state != currentState) {
    currentState = state;
    if (state) {
      $('.side-menu-bg-mid').removeAttr('id');
    } else {
      $('.side-menu-bg-mid').attr('id', 'side-menu');
    }
  }
}

setSize();
$(window).on('resize', setSize);
</script>
