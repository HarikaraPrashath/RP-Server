<script language="JavaScript">
    javascript:window.history.forward(1);
    
    window.VIEW_SETTING = 'LIST_VIEW';
    window.vacancyView = {
            LIST_VIEW: 'LIST_VIEW',  
            GRID_VIEW: 'GRID_VIEW' 
    };
    
    //Openes popup window for a given url, width, height and window name
    //The address bar and toolbar are not shown in this popup.
    function openSizeWindow(url,width,height,name)
    {
        var ht = screen.height;
        var wdth = screen.width;
        var newWidth = width;
        var newHeight = height;
        var lft = (wdth / 2) - (newWidth / 2);
        var tp = (ht / 2) - (newHeight / 2);
        var w = window.open (url, name, "location=no,screen x=200,screen y=200,toolbar=no,directories=no,status=no, menubar=no,scrollbars=yes,resizable=yes,copyhistory=no,left="+ lft + ",top="+ tp +",width="+ newWidth  +",height="+ newHeight);
    }
    
    //Text search box is cleared, when the search button is clicked 
    //and if the text box has the words 'Search by keywords'
    //Changed for search by ref number. cc3203
    function clearBox(comp)
    {
        if((comp.name == "txtKeyWord"))
        {
            if(document.frmQuickVacancySearch.txtKeyWord.value == "Search by keywords")
            {
                    //set the keyword textbox empty
                    document.frmQuickVacancySearch.txtKeyWord.value = "";
            }
        }else if(comp.name =="txtJSCode"){
            if(document.frmQuickVacancySearch.txtJSCode.value == "Search by Job Ref Number"){
                document.frmQuickVacancySearch.txtJSCode.value = "";
            }
        }else if(comp.name == "btnSearch" || comp.name == "chkGovt" || comp.name == "chkNGO" || comp.name == "chkParttime" || comp.name == "chkWalkin"){
            if(document.frmQuickVacancySearch.txtKeyWord.value == "Search by keywords"){
                document.frmQuickVacancySearch.txtKeyWord.value = "";
            }
            
            if(document.frmQuickVacancySearch.txtJSCode.value == "Search by Job Ref Number"){
                document.frmQuickVacancySearch.txtJSCode.value = "";
            }
        }
    }
    
    //resize panels etc.
    function resizePanels() {
        width = document.documentElement.clientWidth;
        
        //set the width of the main area where all hot jobs gets displayed
        $("#content-main").width(width - 160);
        //sets the width of a single section where a hot job is displayed
        $(".job-column").width((width - 200)/4);    //changed 3 to 4 dilan  
    }
    
    /* CC4517 start */
    /**
     * CC4517: 
     * Submits the search form after confirming that either Job-ref-number or Keyword field has been entered a value. 
     * 
     * If at least either of the fields has a non-empty value, submits the search form.
     * If values for both are empty, submits the search form only on confirmation by the user that they want to continue search with empty params. 
     * If the user chooses not to, form submission is aborted. 
     * 
     * @return 'true' if the search form is to be submitted, and 'false' if it should be aborted.
     */
    function submitSearchForm() {   
        
        // Retrieve search params
        var jsCodeParam = $('#txtJSCode').val();
        var keywordParam = $('#txtKeyWord').val();   
        
        // Check if serach parameters are empty
        if (areParamsEmpty(jsCodeParam, keywordParam)) {
            // If yes, alert the user to the fact; ask if they want to continue the search with empty/invalid params
            var isToSubmit = confirm("Search terms are empty!\n\n" +
            "Please search by entering a Job-Ref Number (e.g. 123456) or Keyword (e.g. accountant). Click OK to continue with empty search terms (only the most recent vacancies will be listed).");
            if (isToSubmit) {
                // If user's response is Yes, return 'true' that will submit form
                return true;
            } else { 
                // Returning 'false' would cancel the default action of the button 
                return false;
            }   
        } else { 
            // This means search params are not empty; submit the form by returning 'true'
            return true;
        }
    }   
    
    /**
     * CC4517: 
     * Checks if jsCodeParam and keywordParam parameters are empty. 
     * If both are empty, returns true. If either is not empty, returns false.
     *  
     * @param jsCodeParam: value to check if empty
     * @param keywordParam: value to check if empty
     * 
     * @return a boolean, with 'true' indicating that both search parameters are empty, and false if either one is not.
     */ 
    function areParamsEmpty(jsCodeParam, keywordParam) {
         
         var paramsEmpty = false; 
         
         if ((jsCodeParam == null || jsCodeParam.trim().length < 1) && (keywordParam == null || keywordParam.trim().length < 1)) {
             paramsEmpty = true;
         }
         
         return paramsEmpty;
    }       
    /* CC4517 end */
    
    
    
    $(document).ready(function(){
        
        //re-set the sizes of the panels/divs upon window resize
        resizePanels();
        
        //re-set the sizes of the panels/divs upon window resize
        $(window).bind('resize', function() { 
                resizePanels();
        });
        
        /* CC4544 start */
        // Bind event handling function to click event of Search button
        $('#btnSearch').on("click", function() {
            return searchByViewType(window.VIEW_SETTING, this);
        });
        /* CC4544 end */
    });
    
    /**
     * CC4544: 
     * Cotrols the submission of search form based on the type of view VBFA is to be opened in that is indicated by vieType param)
     *  
     * @param viewType: A String indicating the type of view VBFA will open in (e.g. LIST_VIEW, GRID_VIEW)
     * @param elem: The element on which an event was triggered for this method to be invoked
     * 
     * @return a boolean, with 'true' if form is to be submitted, and 'false' if form submission is to be aborted. 
     */ 
    function searchByViewType(viewType, elem) { 
         
        var submit = false;
        var vacancyView = window.vacancyView; 
        
        // Clear any default (placeholder) text in search param boxes 
        clearBox(elem);
        
         if (viewType === vacancyView.GRID_VIEW) {
             submit = submitSearchForm();
         } else if (viewType === vacancyView.LIST_VIEW) {
             submit = true;
         }
         
         return submit;
    }
</script>

<script language="JavaScript">
    //5349CC
